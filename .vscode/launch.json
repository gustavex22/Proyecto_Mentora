{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Yarn: Backend",
      "runtimeExecutable": "yarn",
      "runtimeArgs": [
        "dev"
      ],
      "cwd": "${workspaceFolder}/Mentora/Backend",
      "console": "integratedTerminal", // <-- Esto obliga a que use la terminal de VS Code y no se cierre
      "internalConsoleOptions": "neverOpen",
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Yarn: Frontend",
      "runtimeExecutable": "yarn",
      "runtimeArgs": [
        "dev"
      ],
      "cwd": "${workspaceFolder}/Mentora/FrontEnd",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": [
        "<node_internals>/**"
      ]
    }
  ]
}